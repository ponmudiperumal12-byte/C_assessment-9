#include <stdio.h>

int main()
{
    int a[50], b[50], c[51];
    int i;

    printf("Enter first 50 numbers:\n");
    for(i = 0; i < 50; i++)
        scanf("%d", &a[i]);

    printf("Enter second 50 numbers:\n");
    for(i = 0; i < 50; i++)
        scanf("%d", &b[i]);

    for(i = 0; i < 50; i++)
        c[i] = a[i] + b[i];

    c[50] = 0;

    printf("Result array:\n");
    for(i = 0; i < 51; i++)
        printf("%d ", c[i]);
}
