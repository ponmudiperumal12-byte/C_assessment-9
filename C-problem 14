#include <stdio.h>

int main()
{
    int a[100], i = 0;
     printf ("enter the number:") ;
    while(1)
    {
        scanf("%d", &a[i]);

        if(a[i] == 0)
            break;

        i++;
    }

    if(i % 2 != 0)
        printf("%d", a[i / 2]);
    else
        printf("%d", (a[i / 2 - 1] + a[i / 2]) / 2);
}
