#include <stdio.h>

int main()
{
    int a[5], b[5], i, n, rev, sum = 0;
    printf("enter the number:") ;
    for(i = 0; i < 5; i++)
        scanf("%d", &a[i]);

    for(i = 0; i < 5; i++)
    {
        n = a[i];
        rev = 0;

        while(n > 0)
        {
            rev = rev * 10 + n % 10;
            n = n / 10;
        }

        b[i] = rev;
        sum = sum + b[i];
    }

    printf("%d", sum);

    return 0;
}
