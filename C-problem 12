#include <stdio.h>

int main()
{
    int a[100], i = 0, sum = 0;
    printf ("enter the number:") ;
    while(1)
    {
        scanf("%d", &a[i]);

        if(a[i] == 0)
            break;

        sum = sum + a[i];
        i++;
    }

    printf("Total numbers = %d\n", i);
    printf("Sum = %d", sum);
}
